# Copy to .env and adjust. Every path the engine touches is an env var, so
# migrating state to a NAS later is a config change, not a code change.

# --- State paths -----------------------------------------------------------
# Ledger (SQLite): source of truth for jobs + failures.
XDL_DB=./data/ledger.db
# yt-dlp download-archive: one line per already-downloaded video -> dedup.
XDL_ARCHIVE=./data/archive.txt
# Where finished desktop downloads land.
XDL_DOWNLOAD_DIR=./data/downloads
# Where async/iOS downloads stage until the collector saves them to Photos.
XDL_STAGING_DIR=./data/staging
# Huey's own SQLite queue file.
XDL_HUEY_DB=./data/huey.db

# --- Auth ------------------------------------------------------------------
# Optional Netscape-format cookie file from the BURNER account. Used only as a
# fallback when an anonymous download hits a login/sensitive-content wall.
# Leave unset for anonymous-only. Treat as a credential (chmod 600); never commit.
# XDL_COOKIES=./secrets/cookies.txt

# --- Behaviour -------------------------------------------------------------
# Whole-post retry attempts (spec: 3, 60s apart). Controls the ledger lifecycle.
XDL_MAX_ATTEMPTS=3
XDL_RETRY_DELAY=60
# Huey consumer worker count (concurrency). Per-download speed comes from -N.
XDL_WORKERS=4
# yt-dlp concurrent HLS fragment downloads (native -N).
XDL_FRAGMENTS=4

# --- Server ----------------------------------------------------------------
XDL_HOST=0.0.0.0
XDL_PORT=8080
# Optional shared-secret header (belt-and-suspenders on top of Tailscale).
# If set, every request must send  X-XDL-Token: <value>
# XDL_SHARED_SECRET=change-me
